{
  "name": "ai-placement-hub",
  "version": "1.0.0",
  "description": "AI-powered Interview Preparation Platform — Monorepo Root",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n \"CLIENT,SERVER\" -c \"cyan,magenta\" \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=server",
    "lint": "npm run lint --workspace=client",
    "format": "npm run format --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
