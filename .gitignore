# ============================================================
# AI-Placement-Hub — .gitignore
# ============================================================

# ─── Node.js ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json.bak

# ─── Environment Variables ──────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ─── Vite / Build Outputs ───────────────────────────────────
client/dist/
client/.vite/
*.local

# ─── Prisma ─────────────────────────────────────────────────
server/prisma/migrations/dev.db
server/prisma/dev.db
server/prisma/*.db
server/prisma/*.db-journal

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
combined.log
error.log

# ─── OS Artifacts ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE & Editor ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates

# ─── Test Coverage ──────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ───────────────────────────────────────────────────
*.pem
*.p12
.cache/
.parcel-cache/
