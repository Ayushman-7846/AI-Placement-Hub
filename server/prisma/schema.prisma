// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

// ── Generator ────────────────────────────────────────────────────
// Generates the Prisma Client — the type-safe database client
// used in all service files.
//
// After any schema changes, run: npm run db:generate
generator client {
  provider = "prisma-client-js"
  // output  = "../src/generated/prisma" // Optional: custom output path
}

// ── Datasource ────────────────────────────────────────────────────
// Defines the database provider.
// ⚠️  PRISMA 7 BREAKING CHANGE:
//     The `url` property is no longer in schema.prisma.
//     Connection URL is now configured in prisma.config.js (see server/prisma.config.js).
//
// ⚠️  IMPORTANT: Only PostgreSQL is used in this project.
//     Do NOT change the provider to sqlite, mysql, or mongodb.
datasource db {
  provider = "postgresql"
  // NOTE: url is NOT here in Prisma 7 — it's in prisma.config.js
}

// ── Enums ─────────────────────────────────────────────────────────

/// User roles for role-based access control.
/// USER  — standard authenticated user
/// ADMIN — administrative user with elevated privileges
enum UserRole {
  USER
  ADMIN
}

// ── Models (Phase 2A) ─────────────────────────────────────────────
//
// Database Design Standards (enforced):
//  ✅ UUID primary keys — @id @default(uuid())
//  ✅ snake_case field names — created_at, user_id, deleted_at
//  ✅ created_at + updated_at on every model
//  ✅ @@map() for explicit table names
//  ✅ Soft delete via deleted_at (nullable DateTime)
//  ❌ NEVER use auto-increment integer IDs
//
// Planned Models (Phase 3+):
//   - InterviewSession
//   - InterviewAnswer
//   - ResumeAnalysis
//   - ProgressRecord

/// Core user record.
/// Soft-deleted via deleted_at — never hard-deleted.
/// password is a bcrypt hash — never returned in API responses.
model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  role       UserRole  @default(USER)
  deleted_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  refresh_tokens RefreshToken[]
  sessions       InterviewSession[]

  @@map("users")
}

/// Refresh token store — one user may have many active tokens
/// (e.g., multiple devices). Token rotation revokes the old record
/// and inserts a new one atomically inside a transaction.
model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  expires_at DateTime

  created_at DateTime @default(now())

  // Foreign key
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ── Models (Phase 4A) ─────────────────────────────────────────────

enum InterviewStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}

enum QuestionType {
  TECHNICAL
  BEHAVIORAL
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  MIXED
}

model InterviewSession {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  title         String
  role          String
  difficulty    String
  interviewType InterviewType   @map("interview_type")
  status        InterviewStatus @default(CREATED)
  questionCount Int             @map("question_count")
  overallScore  Int?            @map("overall_score")
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions InterviewQuestion[]
  answers   InterviewAnswer[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("interview_sessions")
}

model InterviewQuestion {
  id           String       @id @default(uuid())
  sessionId    String       @map("session_id")
  question     String       @db.Text
  questionType QuestionType @map("question_type")
  order        Int
  createdAt    DateTime     @default(now()) @map("created_at")

  session InterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers InterviewAnswer[]

  @@index([sessionId])
  @@map("interview_questions")
}

model InterviewAnswer {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  questionId  String   @map("question_id")
  answer      String   @db.Text
  score       Int
  strengths   Json
  weaknesses  Json
  suggestions Json
  feedback    String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  session  InterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([questionId])
  @@map("interview_answers")
}
