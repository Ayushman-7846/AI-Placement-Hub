# Backend Environment Variables — Example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────────────────────
# Port the Express server listens on
# Render sets this automatically in production
PORT=5000

# Node environment: development | test | production
NODE_ENV=development

# ──────────────────────────────────────────────────────────────
# Database — PostgreSQL 16+
# ──────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Development example: postgresql://postgres:password@localhost:5432/ai_placement_hub
# Render: Copy from your Render PostgreSQL service dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_placement_hub

# ──────────────────────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────────────────────
# Access token secret — short-lived tokens (15 minutes)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_access_key_replace_this_in_production

# Refresh token secret — long-lived tokens (7 days)
# Must be DIFFERENT from JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_replace_this_in_production

# Access token expiry (e.g., 15m, 1h, 24h)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiry (e.g., 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────
# Google Gemini AI
# ──────────────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
# Uses @google/genai package (NOT the deprecated @google/generative-ai)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use for AI features
GEMINI_MODEL=gemini-2.0-flash

# ──────────────────────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────────────────────
# Frontend origin URL — used by CORS middleware
# Development: http://localhost:3000
# Production: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=100

# Rate limit window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
