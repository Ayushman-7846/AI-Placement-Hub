{
  "name": "ai-placement-hub-server",
  "version": "1.0.0",
  "description": "AI-Placement-Hub Backend — Express 5 + Prisma 7 + PostgreSQL 16",
  "private": true,
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:generate": "prisma generate --config prisma.config.js",
    "db:migrate": "prisma migrate dev --config prisma.config.js",
    "db:migrate:prod": "prisma migrate deploy --config prisma.config.js",
    "db:validate": "prisma validate --config prisma.config.js",
    "db:studio": "prisma studio --config prisma.config.js",
    "db:reset": "prisma migrate reset --config prisma.config.js",
    "db:seed": "node prisma/seed.js",
    "lint": "eslint src/**/*.js --max-warnings 0",
    "format": "prettier --write \"src/**/*.js\" \"prisma/**/*.prisma\""
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "nodemonConfig": {
    "watch": [
      "src/",
      "prisma/"
    ],
    "ext": "js,json,prisma",
    "ignore": [
      "node_modules/",
      "logs/"
    ],
    "delay": 500
  }
}
